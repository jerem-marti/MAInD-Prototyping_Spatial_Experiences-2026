[Unit]
Description=Shadow Creatures Kiosk (Chromium fullscreen)
# Wait for the Wayland/labwc desktop session and the backend HTTP server
After=graphical-session.target shadow-backend.service
Wants=shadow-backend.service

[Service]
Type=simple
ExecStartPre=/bin/sleep 4
ExecStart=/home/jermarti/maind-deploy/scripts/kiosk.sh http://localhost:8080
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
