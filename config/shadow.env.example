# Shadow Creatures — Exhibition Mode Configuration
# No hardware dependencies: no camera, no IMU, no battery gauge, no GPIO

# Kismet API (WiFi/BT scanner at 127.0.0.1)
KISMET_URL=http://127.0.0.1:2501
KISMET_USER=shadow
KISMET_PASS=change-this-now

# Paths (Pi deploy or local exhibition setup)
GHOST_STATE_PATH=/home/pi/shadow-creatures/state/ghost_state.json
SALT_FILE=/home/pi/shadow-creatures/state/salt.txt
WEB_DIR=/home/pi/shadow-creatures/src/web

# Server (Flask/aiohttp web server + WebSocket relay)
HTTP_PORT=8080