# Kismet API
KISMET_URL=http://127.0.0.1:2501
KISMET_USER=shadow
KISMET_PASS=change-this-now

# Paths (Pi deploy)
GHOST_STATE_PATH=/home/jermarti/maind-deploy/state/ghost_state.json
SALT_FILE=/home/jermarti/maind-deploy/state/salt.txt
SNAP_DIR=/home/jermarti/maind-deploy/state/snapshots
WEB_DIR=/home/jermarti/maind-deploy/src/web
GALLERY_DIR=/home/jermarti/maind-deploy/src/gallery

# Server
HTTP_PORT=8080

# GPIO - Buttons
BTN_SNAPSHOT=12
BTN_MODE=26

# GPIO - LEDs
LED_POWER=20
LED_SENSE=13

# IMU (LSM6DS) - Optional, auto-detected
IMU_BUS=1
IMU_ADDR=0x6A
IMU_RATE_HZ=50

# Battery Fuel Gauge (MAX17040) - Optional, auto-detected
BAT_BUS=1
BAT_ADDR=0x36
BAT_RATE_HZ=0.2
