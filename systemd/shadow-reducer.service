[Unit]
Description=Shadow Creatures Reducer (Kismet -> ghost_state.json)
After=network.target

[Service]
Type=simple
User=jermarti
WorkingDirectory=__DEPLOY_DIR__
EnvironmentFile=__DEPLOY_DIR__/config/shadow.env
ExecStart=/usr/bin/python3 __DEPLOY_DIR__/src/reducer/reducer.py
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
